# ── Firebase Frontend (Vite) ──────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# ── Firebase Admin (Backend server.js) ───────────────────
# Option A: ضع الـ service account JSON كـ string مشفرة بـ base64
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_encoded_service_account_json

# Option B: مسار ملف الـ service account محلياً (للـ dev فقط)
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# ── Server ───────────────────────────────────────────────
PORT=4000
