rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get the current user's profile document
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function to check if the current user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the user is an Admin
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }
    
    // Helper function to check if the user is a Team Leader
    function isTeamLeader() {
      return isAuthenticated() && getUserData().role == 'team_leader';
    }

    // Helper function to check if the user is an Agent
    function isAgent() {
      return isAuthenticated() && getUserData().role == 'agent';
    }

    // ─── Users Collection Security Rules ─────────────────────────────────────
    match /users/{userId} {
      // Authenticated users can read other profiles to resolve names/roles
      allow read: if isAuthenticated();
      
      // Only admins can register/create new users
      allow create, delete: if isAdmin();
      
      // Users can update their own profile fields (e.g. name), admins can update anything
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'username', 'email', 'teamId', 'teamLeaderId']));
    }

    // ─── Leads Collection Security Rules ─────────────────────────────────────
    match /leads/{leadId} {
      // Read access control:
      // - Admins can read all leads
      // - Team leaders can read leads in their shared team
      // - Agents can read their own assigned leads
      allow read: if isAdmin() || 
                  (isTeamLeader() && resource.data.teamId == getUserData().teamId) || 
                  (isAgent() && resource.data.agentId == request.auth.uid);
      
      // Write access control:
      // - Admins can write anything
      // - Team leaders/Agents can create/update leads that comply with ownership boundaries
      allow create, update: if isAdmin() || 
                            (isTeamLeader() && request.resource.data.teamId == getUserData().teamId) || 
                            (isAgent() && request.resource.data.agentId == request.auth.uid);
      
      // Only Admins (and authorized Hamza override if needed) can delete leads
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == 'hamza'); // Or standard admin restriction
    }

    // ─── Trips Collection Security Rules ─────────────────────────────────────
    match /trips/{tripId} {
      // Authenticated members can read trip manifests
      allow read: if isAuthenticated();
      
      // Creation, update, and deletion is restricted to Admins and Team Leaders
      allow write: if isAdmin() || isTeamLeader();
    }
    
    // ─── Archives & Totals Collection Security Rules ─────────────────────────
    match /monthly_archives/{archiveId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /monthly_totals/{totalId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
